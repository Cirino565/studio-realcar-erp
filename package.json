{
  "name": "studio-realcar-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 0.0.0.0",
    "build": "prisma generate --schema=prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint",

    "postinstall": "node scripts/prisma-generate-auto.mjs",

    "setup:local": "node scripts/use-sqlite-local.mjs && prisma generate --schema=prisma/schema.sqlite.prisma && prisma db push --schema=prisma/schema.sqlite.prisma && prisma db seed --schema=prisma/schema.sqlite.prisma",

    "db:push": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.sqlite.prisma",

    "dev:turbo": "next dev --turbopack --hostname 0.0.0.0",
    "dev:local": "next dev --webpack",
    "mobile:test": "next dev --webpack --hostname 0.0.0.0",

    "mobile": "npm run build:local && next start -H 0.0.0.0 -p 3000",
    "start:mobile": "next start -H 0.0.0.0 -p 3000",

    "setup:dev": "npm run setup:local",

    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",

    "db:seed": "prisma db seed --schema=prisma/schema.sqlite.prisma",

    "deploy:check": "prisma generate --schema=prisma/schema.prisma && prisma validate --schema=prisma/schema.prisma && next build",

    "secret:generate": "node scripts/generate-session-secret.mjs",

    "setup:sqlite": "npm run setup:local",

    "build:local": "prisma generate --schema=prisma/schema.sqlite.prisma && next build",

    "setup:postgres": "prisma generate --schema=prisma/schema.prisma && prisma migrate deploy --schema=prisma/schema.prisma && prisma db seed --schema=prisma/schema.prisma",

    "db:seed:postgres": "prisma db seed --schema=prisma/schema.prisma",
    "db:push:postgres": "prisma db push --schema=prisma/schema.prisma",
    "db:studio:postgres": "prisma studio --schema=prisma/schema.prisma",

    "start:host": "node scripts/start-host.mjs",

    "hosting:check-env": "node scripts/verify-hosting-env.mjs",

    "deploy:build": "prisma generate --schema=prisma/schema.prisma && prisma migrate deploy --schema=prisma/schema.prisma && prisma db seed --schema=prisma/schema.prisma && next build",

    "deploy:build:no-seed": "prisma generate --schema=prisma/schema.prisma && prisma migrate deploy --schema=prisma/schema.prisma && next build",

    "deploy:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",

    "deploy:seed": "prisma db seed --schema=prisma/schema.prisma",

    "setup:hosting": "npm run setup:postgres"
  },

  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "prisma": "^6.19.3",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },

  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },

  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },

  "engines": {
    "node": ">=20.11.0"
  }
}