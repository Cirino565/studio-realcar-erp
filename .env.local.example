# Ambiente local rapido, sem Docker, usando SQLite.
# Voce nao precisa copiar este arquivo manualmente: npm run setup:local cria o .env local automaticamente.
DATABASE_URL="file:./dev.db"

# Gere outra chave com: npm run secret:generate
SESSION_SECRET="studio-realcar-local-session-secret-change-before-production-2026"

# Administrador inicial criado pelo seed local
ADMIN_EMAIL="admin@studiorealcar.com"
ADMIN_PASSWORD="123456"
ADMIN_NAME="Administrador"
ADMIN_RESET_PASSWORD="false"

# Usuario operacional local criado pelo seed para testar agenda e clientes
OPERATIONAL_EMAIL="operacional@studiorealcar.com"
OPERATIONAL_PASSWORD="123456"
OPERATIONAL_NAME="Operacional"
OPERATIONAL_RESET_PASSWORD="false"
