# Escolha um modo:
# 1) Local sem Docker: rode npm run setup:local. Ele cria o .env com SQLite.
# 2) Hospedagem: use as variaveis abaixo no painel da hospedagem com PostgreSQL.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
SESSION_SECRET="COLE_AQUI_UMA_CHAVE_COM_PELO_MENOS_32_CARACTERES"

ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="troque-por-uma-senha-forte"
ADMIN_NAME="Administrador"
ADMIN_RESET_PASSWORD="false"

OPERATIONAL_EMAIL="operacional@seudominio.com"
OPERATIONAL_PASSWORD="troque-por-uma-senha-forte"
OPERATIONAL_NAME="Operacional"
OPERATIONAL_RESET_PASSWORD="false"
