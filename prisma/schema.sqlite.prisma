generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id           Int      @id @default(autoincrement())
  nome         String
  telefone     String
  whatsapp     String?
  cpf          String?
  instagram    String?
  origem       String?
  procedimentoInteresse String?
  nascimento   DateTime?
  observacoes  String?
  procedimento String?
  valorGasto   Float    @default(0)
  ultimaVisita DateTime?
  status       String   @default("Ativa")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agendamentos Agendamento[]
  anamneses    ClienteAnamnese[]
  fotos        ClienteFoto[]
  documentos   ClienteDocumento[]
  procedimentos ClienteProcedimento[]
  evolucoes    ClienteEvolucao[]
  anamneseRespostas ClienteAnamneseResposta[]
  leads          Lead[]
  comunicacoes   ComunicacaoRegistro[]
  vendas          Venda[]
}

model OrigemCliente {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?
  status      String   @default("Ativa")
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProcedimentoInteresse {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?
  status      String   @default("Ativo")
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model ProcedimentoServico {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  categoria     String?
  descricao     String?
  duracaoPadrao Int      @default(60)
  valorPadrao   Float    @default(0)
  custoPadrao   Float    @default(0)
  status        String   @default("Ativo")
  ordem         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  anamneseModelos AnamneseModelo[]
  itensVenda      VendaItem[]
}

model Agendamento {
  id             Int           @id @default(autoincrement())
  clienteId      Int
  cliente        Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  profissionalId Int?
  profissional   Profissional? @relation(fields: [profissionalId], references: [id], onDelete: SetNull)
  procedimento   String
  data           DateTime
  duracao        Int           @default(60)
  valor          Float         @default(0)
  observacoes    String?
  status               String        @default("Agendado")
  serieId              String?
  recorrenciaTipo      String?
  recorrenciaIntervalo Int?
  recorrenciaIndice    Int?
  recorrenciaTotal     Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  lead                 Lead?
  comunicacoes          ComunicacaoRegistro[]
  vendas                Venda[]

  @@index([serieId])
}

model Profissional {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  area          String?
  cor           String   @default("violet")
  telefone      String?
  email         String?
  status        String   @default("Ativa")
  ordem         Int      @default(0)
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agendamentos  Agendamento[]
  bloqueiosAgenda BloqueioAgenda[]
}

model BloqueioAgenda {
  id             Int           @id @default(autoincrement())
  profissionalId Int
  profissional   Profissional  @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  data           DateTime
  duracao        Int           @default(60)
  motivo         String
  observacoes    String?
  status               String        @default("Ativo")
  serieId              String?
  recorrenciaTipo      String?
  recorrenciaIntervalo Int?
  recorrenciaIndice    Int?
  recorrenciaTotal     Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([profissionalId, data])
  @@index([serieId])
}

model Lancamento {
  id              Int      @id @default(autoincrement())
  descricao       String
  valor           Float
  tipo            String
  categoria       String?
  observacoes     String?
  data            DateTime
  formaPagamento  String?
  statusPagamento String   @default("Pago")
  origem          String?
  agendamentoId   Int?
  clienteId       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  venda           Venda?
}

model Fornecedor {
  id          Int      @id @default(autoincrement())
  nome        String
  telefone    String?
  email       String?
  cnpj        String?
  endereco    String?
  observacoes String?
  status      String   @default("Ativo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  produtos    Produto[]
  compras     Compra[]
}

model Produto {
  id             Int      @id @default(autoincrement())
  fornecedorId   Int?
  fornecedor     Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  nome           String
  categoria      String?
  unidade        String   @default("un")
  quantidade     Int      @default(0)
  estoqueMinimo  Int      @default(0)
  valorCompra    Float    @default(0)
  valorVenda     Float    @default(0)
  status         String   @default("Ativo")
  observacoes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movimentacoes  MovimentacaoEstoque[]
  itensCompra    CompraItem[]
  itensVenda     VendaItem[]
}

model MovimentacaoEstoque {
  id          Int      @id @default(autoincrement())
  produtoId   Int
  produto     Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  vendaItemId Int?     @unique
  vendaItem   VendaItem? @relation(fields: [vendaItemId], references: [id], onDelete: SetNull)
  tipo        String
  quantidade  Int
  motivo      String
  observacoes String?
  createdAt   DateTime @default(now())
}

model Venda {
  id                  Int       @id @default(autoincrement())
  clienteId           Int?
  cliente             Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  agendamentoId       Int?
  agendamento         Agendamento? @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)
  lancamentoId        Int?      @unique
  lancamento          Lancamento? @relation(fields: [lancamentoId], references: [id], onDelete: SetNull)
  totalServicos       Float     @default(0)
  totalProdutos       Float     @default(0)
  custoServicos       Float     @default(0)
  custoProdutos       Float     @default(0)
  valorTotal          Float     @default(0)
  custoTotal          Float     @default(0)
  formaPagamento      String?
  statusPagamento     String    @default("Pago")
  origem              String    @default("Venda")
  observacoes         String?
  data                DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  itens               VendaItem[]

  @@index([clienteId, data])
  @@index([agendamentoId, data])
  @@index([data])
  @@index([statusPagamento, data])
}

model VendaItem {
  id                    Int       @id @default(autoincrement())
  vendaId               Int
  venda                 Venda     @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  tipo                  String
  produtoId             Int?
  produto               Produto?  @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  procedimentoServicoId Int?
  procedimentoServico   ProcedimentoServico? @relation(fields: [procedimentoServicoId], references: [id], onDelete: SetNull)
  descricao             String
  quantidade            Int       @default(1)
  valorUnitario         Float     @default(0)
  custoUnitario         Float     @default(0)
  valorTotal            Float     @default(0)
  custoTotal            Float     @default(0)
  createdAt             DateTime  @default(now())

  movimentacao          MovimentacaoEstoque?

  @@index([vendaId])
  @@index([produtoId])
  @@index([procedimentoServicoId])
  @@index([tipo])
}

model Compra {
  id           Int      @id @default(autoincrement())
  fornecedorId Int?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  descricao    String
  valorTotal   Float    @default(0)
  status       String   @default("Aberta")
  data         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  itens        CompraItem[]
}

model CompraItem {
  id        Int     @id @default(autoincrement())
  compraId  Int
  compra    Compra  @relation(fields: [compraId], references: [id], onDelete: Cascade)
  produtoId Int
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)
  quantidade Int
  valorUnitario Float
}

model Lead {
  id               Int       @id @default(autoincrement())
  nome             String
  telefone         String?
  origem           String?
  interesse        String?
  etapa            String    @default("Novo")
  valorPrevisto    Float     @default(0)
  observacoes      String?
  motivoPerda      String?
  ultimoContatoEm  DateTime?
  proximoContatoEm DateTime?
  convertidoEm     DateTime?
  clienteId        Int?
  cliente          Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  ignorarVinculoTelefone Boolean @default(false)
  agendamentoId    Int?      @unique
  agendamento      Agendamento? @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)
  campanhaId       Int?
  campanha         CampanhaMarketing? @relation(fields: [campanhaId], references: [id], onDelete: SetNull)
  interacoes       LeadInteracao[]
  comunicacoes      ComunicacaoRegistro[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clienteId])
  @@index([campanhaId])
  @@index([etapa])
  @@index([proximoContatoEm])
}

model LeadInteracao {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tipo      String
  descricao String?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model CampanhaMarketing {
  id                Int      @id @default(autoincrement())
  nome              String
  canal             String
  investimento      Float    @default(0)
  leads             Int      @default(0)
  status            String   @default("Ativa")
  inicio            DateTime?
  fim               DateTime?
  leadsRelacionados Lead[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Usuario {
  id             Int       @id @default(autoincrement())
  nome           String
  email          String    @unique
  senha          String
  telefone       String?
  cargo          String?
  tipo           String    @default("Equipe")
  especialidade  String?
  status         String    @default("Ativo")
  perfilId       Int?
  perfil         Perfil?   @relation(fields: [perfilId], references: [id], onDelete: SetNull)
  dataAdmissao   DateTime?
  ultimoAcesso   DateTime?
  observacoes    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Perfil {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?
  nivel       Int      @default(1)
  status      String   @default("Ativo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarios    Usuario[]
  permissoes  PerfilPermissao[]
}

model Permissao {
  id          Int      @id @default(autoincrement())
  chave       String   @unique
  nome        String
  modulo      String
  createdAt   DateTime @default(now())

  perfis      PerfilPermissao[]
}

model PerfilPermissao {
  id          Int       @id @default(autoincrement())
  perfilId    Int
  perfil      Perfil    @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  permissaoId Int
  permissao   Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@unique([perfilId, permissaoId])
}

model Auditoria {
  id          Int      @id @default(autoincrement())
  modulo      String
  acao        String
  entidade    String?
  entidadeId  String?
  usuario     String?
  detalhes    String?
  createdAt   DateTime @default(now())
}

model ConfiguracaoClinica {
  id                    Int      @id @default(autoincrement())
  nome                  String   @default("Studio Realçar")
  razaoSocial           String?
  cnpj                  String?
  telefone              String?
  whatsapp              String?
  email                 String?
  site                  String?
  instagram             String?
  endereco              String?
  bairro                String?
  cidade                String?
  estado                String?
  cep                   String?
  responsavelTecnico    String?
  registroProfissional  String?
  especialidadePrincipal String?
  horarioAtendimento   String?
  intervaloAgenda       Int      @default(30)
  antecedenciaLembrete  Int      @default(24)
  toleranciaAtraso      Int      @default(10)
  moeda                 String   @default("BRL")
  timezone              String   @default("America/Sao_Paulo")
  logoUrl               String?
  corPrincipal          String   @default("violet")
  assinaturaMensagem    String?
  mensagemConfirmacao   String?
  mensagemLembrete      String?
  mensagemRetorno       String?
  politicaCancelamento  String?
  observacoesInternas   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model BackupRegistro {
  id          Int      @id @default(autoincrement())
  nome        String
  status      String   @default("Concluído")
  tamanho     String?
  observacoes String?
  createdAt   DateTime @default(now())
}

model Automacao {
  id              Int       @id @default(autoincrement())
  nome            String
  tipo            String    @default("Operacional")
  gatilho         String
  acao            String
  canal           String?
  frequencia      String    @default("Manual")
  prioridade      String    @default("Média")
  status          String    @default("Ativa")
  proximaExecucao DateTime?
  ultimaExecucao  DateTime?
  execucoes       Int       @default(0)
  falhas          Int       @default(0)
  observacoes     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model MensagemModelo {
  id          Int      @id @default(autoincrement())
  chave       String   @unique
  nome        String
  categoria   String
  corpo       String
  ativo       Boolean  @default(true)
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comunicacoes ComunicacaoRegistro[]
}

model ComunicacaoRegistro {
  id               Int             @id @default(autoincrement())
  modeloId         Int?
  modelo           MensagemModelo? @relation(fields: [modeloId], references: [id], onDelete: SetNull)
  clienteId        Int?
  cliente          Cliente?        @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  leadId           Int?
  lead             Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agendamentoId    Int?
  agendamento      Agendamento?    @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)
  destinatarioNome String
  telefone         String?
  categoria        String
  canal            String          @default("WhatsApp")
  mensagem         String
  status           String          @default("Aberta")
  usuario          String?
  abertoEm         DateTime?
  enviadoEm        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([clienteId, createdAt])
  @@index([leadId, createdAt])
  @@index([agendamentoId, createdAt])
  @@index([categoria, createdAt])
  @@index([status, createdAt])
}


model ClienteAnamnese {
  id                    Int      @id @default(autoincrement())
  clienteId             Int
  cliente               Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  procedimento          String?
  queixaPrincipal        String?
  alergias              String?
  medicamentos          String?
  doencasPreExistentes  String?
  procedimentosAnteriores String?
  gestante              Boolean  @default(false)
  lactante              Boolean  @default(false)
  usaAcidos             Boolean  @default(false)
  possuiMarcapasso      Boolean  @default(false)
  restricoes            String?
  objetivoTratamento    String?
  observacoesClinicas   String?
  respostasRapidas      String?
  assinaturaCliente     String?
  termoConsentimento    Boolean  @default(false)
  profissional          String?
  dataFicha             DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ClienteFoto {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  titulo        String
  tipo          String   @default("Evolução")
  url           String
  descricao     String?
  dataRegistro  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ClienteDocumento {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  titulo        String
  tipo          String   @default("Documento")
  url           String?
  observacoes   String?
  dataRegistro  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ClienteProcedimento {
  id              Int      @id @default(autoincrement())
  clienteId       Int
  cliente         Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nome            String
  profissional    String?
  valor           Float    @default(0)
  status          String   @default("Realizado")
  dataProcedimento DateTime @default(now())
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ClienteEvolucao {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  titulo        String
  descricao     String
  profissional  String?
  dataRegistro  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model AnamneseModelo {
  id              Int      @id @default(autoincrement())
  nome            String
  procedimentoId  Int?
  procedimento    ProcedimentoServico? @relation(fields: [procedimentoId], references: [id], onDelete: SetNull)
  procedimentoNome String?
  descricao       String?
  status          String   @default("Ativo")
  ordem           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  perguntas       AnamnesePergunta[]
  respostas       ClienteAnamneseResposta[]
}

model AnamnesePergunta {
  id            Int      @id @default(autoincrement())
  modeloId      Int
  modelo        AnamneseModelo @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  pergunta      String
  tipo          String   @default("SIM_NAO")
  opcoes        String?
  obrigatoria   Boolean  @default(false)
  ativa         Boolean  @default(true)
  ordem         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  respostas     ClienteAnamneseResposta[]
}

model ClienteAnamneseResposta {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  modeloId      Int?
  modelo        AnamneseModelo? @relation(fields: [modeloId], references: [id], onDelete: SetNull)
  perguntaId    Int?
  pergunta      AnamnesePergunta? @relation(fields: [perguntaId], references: [id], onDelete: SetNull)
  procedimento  String?
  perguntaTexto String
  tipo          String
  resposta      String?
  observacao    String?
  profissional  String?
  dataResposta  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
